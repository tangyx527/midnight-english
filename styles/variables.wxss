/* ===== Midnight English · 设计系统 =====
  风格：MUJI + 深夜便利店 + 小红书轻文艺
  所有设计令牌集中管理，组件通过 var(--xxx) 引用
  禁止硬编码颜色、间距、字号、阴影
*/

page {
  /* ========================================
     色彩系统 · Color Palette
     ========================================
     主背景：米白暖灰 — 大面积底色，呼吸感
     卡片背景：柔和浅米白 — 内容容器
     文字：深夜灰系 — 克制对比度
     强调色：莫兰迪灰蓝 — 低饱和高级感
     边框：极淡暖灰 — 若有若无的分割
  */

  /* 背景色 */
  --color-bg: #FAF8F5;              /* 主背景 · 米白暖灰 */
  --color-bg-card: #F5F3F0;         /* 卡片背景 · 柔和浅米白 */
  --color-bg-elevated: #FCFBFA;     /* 浮层背景 · 近白但温润 */

  /* 文字色 */
  --color-text: #3A3A3A;            /* 主文字 · 深夜灰 */
  --color-text-secondary: #8B8B8B;  /* 次文字 · 柔和灰 */
  --color-text-hint: #B8B5B1;       /* 提示文字 · 淡灰褐 */

  /* 强调色 — 莫兰迪灰蓝 */
  --color-accent: #6B7B8D;          /* 主强调 · 灰蓝 */
  --color-accent-light: #96A5B3;    /* 浅强调 · 淡灰蓝 */
  --color-accent-bg: #EDF0F2;       /* 强调背景 · 极淡灰蓝 */

  /* 收藏色 — 灰玫瑰 */
  --color-fav: #C4A29E;             /* 收藏心形 · 低饱和玫瑰 */
  --color-fav-light: #E8D5D2;       /* 收藏浅色 · 淡玫瑰 */

  /* 分割与边框 */
  --color-border: #EBE8E4;          /* 主分割 · 暖灰 */
  --color-border-light: #F0EDE9;    /* 浅分割 · 极淡暖灰 */

  /* 遮罩层 */
  --color-overlay: rgba(58, 58, 58, 0.35);  /* 弹窗遮罩 · 深夜灰半透明 */

  /* TabBar 专用色 */
  --color-tab-bg: rgba(252, 251, 250, 0.92);  /* TabBar 背景 · 毛玻璃感 */
  --color-tab-border: rgba(235, 232, 228, 0.6); /* TabBar 边框 · 半透明 */
  --color-tab-active-bg: rgba(107, 123, 141, 0.08); /* TabBar 选中态背景 */


  /* ========================================
     圆角系统 · Border Radius
     ========================================
     统一全项目圆角，保持视觉一致性
  */
  --radius-sm: 8rpx;                /* 小圆角 · 按钮/标签 */
  --radius-md: 16rpx;               /* 中圆角 · 卡片/输入框 */
  --radius-lg: 24rpx;               /* 大圆角 · 弹窗/胶囊 */
  --radius-xl: 36rpx;               /* 超大圆角 · TabBar 胶囊 */
  --radius-full: 50%;               /* 全圆角 · 头像 */


  /* ========================================
     阴影系统 · Shadow
     ========================================
     极淡 · 柔和 · 不允许重阴影
  */
  --shadow-card: 0 2rpx 12rpx rgba(58, 58, 58, 0.06);       /* 卡片阴影 · 微悬浮 */
  --shadow-elevated: 0 4rpx 20rpx rgba(58, 58, 58, 0.08);    /* 浮层阴影 · 中度悬浮 */
  --shadow-floating: 0 8rpx 32rpx rgba(58, 58, 58, 0.10);    /* 高层阴影 · 强悬浮 */
  --shadow-inset: inset 0 0 8rpx rgba(58, 58, 58, 0.03);     /* 内阴影 · 收纳盒 */


  /* ========================================
     间距系统 · Spacing
     ========================================
     基于 8rpx 网格，统一全项目间距
  */
  --spacing-xs: 8rpx;               /* 4pt · 极小间距 */
  --spacing-sm: 16rpx;              /* 8pt · 小间距 */
  --spacing-md: 24rpx;              /* 12pt · 中间距 */
  --spacing-lg: 32rpx;              /* 16pt · 大间距 */
  --spacing-xl: 48rpx;              /* 24pt · 超大间距 */
  --spacing-xxl: 64rpx;             /* 32pt · 巨大间距 */


  /* ========================================
     字体大小系统 · Font Size
     ========================================
  */
  --font-xs: 22rpx;                 /* 辅助文字 · 标签/提示 */
  --font-sm: 26rpx;                 /* 小字 · 次要信息 */
  --font-md: 30rpx;                 /* 正文 · 默认阅读 */
  --font-lg: 36rpx;                 /* 大字 · 标题 */
  --font-xl: 44rpx;                 /* 特大 · 封面句 */
  --font-xxl: 56rpx;                /* 超大 · 页面标题 */


  /* ========================================
     字重系统 · Font Weight
     ========================================
  */
  --weight-light: 300;              /* 轻 · 英文正文 */
  --weight-regular: 400;            /* 常规 · 中文正文 */
  --weight-medium: 500;             /* 中等 · 次级标题 */
  --weight-semibold: 600;           /* 半粗 · 主标题 */
  --weight-bold: 700;               /* 粗体 · 强调 */


  /* ========================================
     行高系统 · Line Height
     ========================================
  */
  --leading-tight: 1.3;             /* 紧凑 · 标题 */
  --leading-normal: 1.6;            /* 正常 · 正文 */
  --leading-relaxed: 1.8;           /* 宽松 · 英文句子 */
  --leading-loose: 2.0;             /* 极松 · 诗歌/引用 */


  /* ========================================
     字间距 · Letter Spacing
     ========================================
  */
  --tracking-tight: 0.5rpx;         /* 紧凑 · 英文 */
  --tracking-normal: 1rpx;          /* 正常 · 中文 */
  --tracking-wide: 2rpx;            /* 宽松 · 标题 */


  /* ========================================
     动画时长 · Transition Duration
     ========================================
  */
  --transition-fast: 0.15s ease;    /* 快速 · 按压反馈 */
  --transition-normal: 0.28s ease;  /* 正常 · 切换过渡 */
  --transition-slow: 0.4s ease;     /* 慢速 · 展开/收起 */
}
