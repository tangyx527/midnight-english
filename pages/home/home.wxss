page {
  height: 100vh;
  background-color: var(--color-bg);
  overflow: hidden;
}

.home {
  height: 100%;
  position: relative;
}

/* ===== 竖直滑动容器 ===== */
.home__swiper {
  height: 100%;
  width: 100%;
  padding-bottom: calc(136rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.home__swiper-item {
  display: flex;
  align-items: center;
  justify-content: center;
}

/* ===== 卡片内部滚动 ===== */
.home__card-scroll {
  width: 100%;
  height: 100%;
}

.home__card-inner {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 100%;
  box-sizing: border-box;
}

/* ===== 页码指示器 (悬浮) ===== */
.home__indicator {
  position: fixed;
  bottom: calc(136rpx + env(safe-area-inset-bottom) - 6rpx);
  left: 50%;
  transform: translateX(-50%);
  display: flex;
  gap: 10rpx;
  z-index: 100;
  padding: 8rpx 20rpx;
  background: rgba(250, 248, 245, 0.75);
  border-radius: 40rpx;
  backdrop-filter: blur(10rpx);
  -webkit-backdrop-filter: blur(10rpx);
}

.home__dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background-color: var(--color-border);
  transition: all var(--transition-normal);
}

.home__dot--active {
  width: 28rpx;
  border-radius: 5rpx;
  background-color: var(--color-accent);
}
