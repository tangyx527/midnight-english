@import '../../styles/animations.wxss';

/* ===== 卡片容器 ===== */
.ec-card {
  position: relative;
  margin: var(--spacing-sm) var(--spacing-md);
  padding: var(--spacing-lg);
  background-color: var(--color-bg-elevated);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-card);
  transition: opacity var(--transition-fast);
}

.ec-card:active {
  opacity: 0.85;
}

/* ===== 收藏标记 ===== */
.ec-fav-mark {
  position: absolute;
  top: var(--spacing-md);
  right: var(--spacing-md);
  font-size: 30rpx;
  color: var(--color-fav);
  opacity: 0.7;
  animation: favPop 0.3s ease;
}

/* ===== 元信息行 ===== */
.ec-meta {
  display: flex;
  align-items: center;
  margin-bottom: var(--spacing-md);
  padding-right: 40rpx;
}

.ec-meta__item {
  font-size: var(--font-xs);
  color: var(--color-text-hint);
  letter-spacing: 1rpx;
}

.ec-meta__sep {
  margin: 0 6rpx;
  font-size: var(--font-xs);
  color: var(--color-border);
}

/* ===== 标题 ===== */
.ec-title {
  margin-bottom: var(--spacing-sm);
  display: flex;
  align-items: baseline;
  gap: 8rpx;
}

.ec-title__text {
  font-size: var(--font-lg);
  font-weight: var(--weight-semibold);
  color: var(--color-text);
  line-height: 1.5;
  letter-spacing: 1rpx;
}

.ec-title__hint {
  font-size: 18rpx;
  color: var(--color-text-hint);
  padding: 2rpx 8rpx;
  border: 1rpx solid var(--color-border);
  border-radius: 6rpx;
  flex-shrink: 0;
}

/* ===== 封面引用句 ===== */
.ec-cover {
  margin-bottom: var(--spacing-sm);
}

.ec-cover__text {
  font-size: var(--font-lg);
  color: var(--color-text);
  line-height: 1.7;
  letter-spacing: 1rpx;
}

/* ===== 句子列表 ===== */
.ec-body {
  display: flex;
  flex-direction: column;
  gap: var(--spacing-sm);
}

.ec-sentence {
  padding: 4rpx 0;
}

.ec-sentence__en {
  font-size: var(--font-md);
  color: var(--color-text);
  line-height: 1.8;
  letter-spacing: 0.5rpx;
}

.ec-sentence__zh {
  display: block;
  margin-top: var(--spacing-sm);
  padding-left: var(--spacing-sm);
  font-size: var(--font-sm);
  color: var(--color-text-secondary);
  line-height: 1.6;
  border-left: 2rpx solid var(--color-accent-light);
  animation: fadeInUp var(--transition-normal);
}

/* ===== 关键词高亮 ===== */
.ec-token {
  color: var(--color-accent);
  position: relative;
}

.ec-token::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 1rpx;
  background-color: var(--color-accent-light);
  opacity: 0.4;
}

/* ===== 展开/收起提示 ===== */
.ec-hint {
  margin-top: var(--spacing-md);
  padding-top: var(--spacing-md);
  border-top: 1rpx solid var(--color-border-light);
  text-align: center;
}

.ec-hint__text {
  font-size: var(--font-xs);
  color: var(--color-text-hint);
  letter-spacing: 1rpx;
}
